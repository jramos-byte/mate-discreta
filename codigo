import tkinter as tk
from tkinter import messagebox, ttk
import networkx as nx
import matplotlib.pyplot as plt
from matplotlib.backends.backend_tkagg import FigureCanvasTkAgg

# crear un objeto del tipo grafo utilizando networkx
G = nx.Graph()

# Matriz con las 20 conexiones y sus respectivos tiempos
conexiones = [
    ("Sapporo", "Hakodate", 230), ("Hakodate", "Aomori", 60), 
    ("Aomori", "Sendai", 105), ("Sendai", "Tokio", 90), 
    ("Sendai", "Niigata", 195), ("Niigata", "Tokio", 120), 
    ("Niigata", "Kanazawa", 180), ("Tokio", "Nagoya", 100), 
    ("Tokio", "Kanazawa", 150), ("Nagoya", "Kanazawa", 180), 
    ("Nagoya", "Kioto", 35), ("Nagoya", "Osaka", 50), 
    ("Kanazawa", "Kioto", 135), ("Kioto", "Osaka", 15), 
    ("Osaka", "Okayama", 45), ("Osaka", "Hiroshima", 85), 
    ("Okayama", "Hiroshima", 40), ("Hiroshima", "Fukuoka", 65), 
    ("Fukuoka", "Kumamoto", 40), ("Kumamoto", "Kagoshima", 45)
]

#añade todas las aristas con sus pesos al objeto grafo
G.add_weighted_edges_from(conexiones)

# diccionario que guarda las posiciones (x, y) para representar las ciudades
pos = {
    "Sapporo": (5, 10), "Hakodate": (4.5, 8.5), "Aomori": (4, 7), 
    "Sendai": (3.5, 5), "Niigata": (2.2, 4.8), "Tokio": (3, 3.5), 
    "Kanazawa": (1.8, 3.8), "Nagoya": (2.2, 2.5), "Kioto": (1.5, 2.3), 
    "Osaka": (1.2, 1.8), "Okayama": (0.5, 1.5), "Hiroshima": (-0.2, 1.2), 
    "Fukuoka": (-1, 0.5), "Kumamoto": (-1.2, -0.5), "Kagoshima": (-1.5, -1.5)
}

# funciones de logica y dibujo del grafico 
#  la siguiente funcion se encarga de renderizar el mapa interactivo en la parte derecha de la pantalla, recibiendo como parametro la lista con las ciudades que componen el camino minimo
def mostrar_grafo(camino_optimo):
    for widget in frame_mapa.winfo_children():
        widget.destroy()

    # inicia una nueva figura y un lienzo de dibujo con matplotlib   
    fig, ax = plt.subplots(figsize=(7, 6))
    ax.set_title("Grafo Ponderado de la Red de Ciudades (Japón)", fontsize=11, fontweight='bold')
    
    #dibuja la infraestructura de la red: nodos y lineas
    nx.draw_networkx_nodes(G, pos, ax=ax, node_color='#00a8ff', node_size=350)
    nx.draw_networkx_labels(G, pos, ax=ax, font_size=8, font_weight='bold')
    nx.draw_networkx_edges(G, pos, ax=ax, edge_color='#dcdde1', width=1.5)
    
    if camino_optimo:
        aristas_camino = list(zip(camino_optimo[:-1], camino_optimo[1:]))
        nx.draw_networkx_edges(G, pos, ax=ax, edgelist=aristas_camino, edge_color='#e84118', width=3.5)
        nx.draw_networkx_nodes(G, pos, ax=ax, nodelist=camino_optimo, node_color='#e84118', node_size=400)
        
    #obtiene los atributos numericos de peso de las aristas y los proyecta
    pesos = nx.get_edge_attributes(G, 'weight')
    nx.draw_networkx_edge_labels(G, pos, edge_labels=pesos, font_size=7, ax=ax, label_pos=0.5)
    
    #desactiva la cuadricula y los ejes cartesianos de fondo
    plt.axis('off')
    fig.tight_layout()
    
    #mete el lienzo fisico de matplotlib en el contenedor de tkinter 
    canvas = FigureCanvasTkAgg(fig, master=frame_mapa)
    canvas.draw()
    canvas.get_tk_widget().pack(fill=tk.BOTH, expand=True)

#la siguiente funcion extrae los datos de la interfaz, calcula las rutas optimas y actualiza la pantalla con los resultados matematicos
def procesar_ruta():
    orig = combo_origen.get()
    dest = combo_destino.get()
    
    if orig == dest:
        messagebox.showwarning("Aviso", "El origen y el destino deben ser ciudades distintas.")
        return
        
    try:
        camino = nx.dijkstra_path(G, source=orig, target=dest, weight='weight')
        tiempo_total = nx.dijkstra_path_length(G, source=orig, target=dest, weight='weight')
        
        horas = tiempo_total // 60
        minutos = tiempo_total % 60
        
        txt_resultado.config(state=tk.NORMAL)
        txt_resultado.delete('1.0', tk.END)
        txt_resultado.insert(tk.END, f" RUTA ÓPTIMA:\n" + " -> \n".join(camino) + "\n\n")
        txt_resultado.insert(tk.END, f" TIEMPO TOTAL:\n{tiempo_total} min ({horas}h {minutos}min)")
        txt_resultado.config(state=tk.DISABLED)
        
        mostrar_grafo(camino)
        
    except nx.NetworkXNoPath:
        messagebox.showerror("Error", "No se encontró una conexión válida.")

